# Скопируйте на сервер в ~/garpium-lms/.env
# НЕ коммитьте этот файл с реальными паролями!

DOMAIN=lms.garpium.com
NEXTAUTH_URL=https://lms.garpium.com
NEXT_PUBLIC_APP_URL=https://lms.garpium.com

# Сгенерируйте: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_32_CHARS_MIN

# PostgreSQL — Neon/Supabase (для shared hosting) или локальный Docker (VPS):
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Только для Docker VPS (docker-compose.prod.yml):
POSTGRES_USER=lms
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=corporate_lms

# OAuth — см. docs/OAUTH-SSO.md
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
VK_CLIENT_ID=
VK_CLIENT_SECRET=
TBANK_CLIENT_ID=
TBANK_CLIENT_SECRET=
SBERBANK_CLIENT_ID=
SBERBANK_CLIENT_SECRET=
SBERBANK_CLIENT_CERT_PATH=/opt/garpium-lms/deploy/certs/sber-client.crt
SBERBANK_CLIENT_KEY_PATH=/opt/garpium-lms/deploy/certs/sber-client.key
